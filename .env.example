# Runtime
APP_ENV=development
LOG_LEVEL=INFO

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GEMMA=your_openrouter_gemma_model_id
OPENROUTER_MODEL_HAIKU=your_openrouter_haiku_model_id

# Google AI / Gemma
GOOGLE_AI_API_KEY=your_google_ai_api_key
GOOGLE_GEMMA_MODEL=gemma-4

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_DEFAULT_VOICE_ID=your_default_voice_id
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Imentiv
IMENTIV_API_KEY=your_imentiv_api_key
IMENTIV_BASE_URL=https://api.imentiv.ai/v2
IMENTIV_MOCK=true

# MongoDB
MONGODB_ENABLED=true
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=voxcoach

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
