# Runtime
APP_ENV=development
LOG_LEVEL=INFO

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Example: google/gemma-4-31b-it:free
OPENROUTER_MODEL_GEMMA=your_openrouter_gemma_model_id
OPENROUTER_MODEL_HAIKU=your_openrouter_haiku_model_id

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_DEFAULT_VOICE_ID=your_default_voice_id
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Imentiv
IMENTIV_API_KEY=your_imentiv_api_key
IMENTIV_BASE_URL=https://api.imentiv.ai/v2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
